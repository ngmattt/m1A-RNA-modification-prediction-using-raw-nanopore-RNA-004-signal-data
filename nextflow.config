params {
    raw_mode = false

    hek293t_pod5 = ""
    hela_pod5 = ""
    reference_fasta = ""
    reference_kmer_model = ""
    m1a_bed = ""

    hek293t_labeled_events = ""
    hela_eventalign = ""

    dorado_model = "rna004_130bps_sup@v5.0.0"
    max_reads_per_site = 50
    random_state = 42
    high_confidence_threshold = 0.80

    outdir = "results"

    run_hela_prediction = false
    run_figures = true
}

process {
    executor = "local"
    cpus = 4
    memory = "8 GB"
    time = "8h"
    errorStrategy = "terminate"
}

profiles {
    standard {
        process.conda = null
    }

    conda {
        conda.enabled = true
        process.conda = "${projectDir}/environment.yml"
    }
}
